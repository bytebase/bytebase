{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["* * 31 2 *"],
  "postUpdateOptions": ["gomodTidy", "pnpmDedupe"],
  "allowedPostUpgradeCommands": ["^pnpm install --no-frozen-lockfile$"],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "postUpgradeTasks": {
        "commands": ["pnpm install --no-frozen-lockfile"],
        "fileFilters": ["frontend/pnpm-lock.yaml"],
        "executionMode": "update"
      }
    },
    {
      "groupName": "codingame",
      "matchPackagePatterns": ["^@codingame/", "^monaco-editor$", "^vscode$"]
    },
    {
      "groupName": "google.golang.org/genproto",
      "matchPackagePatterns": ["^google.golang.org/genproto"]
    },
    {
      "groupName": "go-toolchain",
      "description": "Group Go version and golangci-lint to avoid version mismatch",
      "matchPackageNames": ["go", "golangci/golangci-lint"]
    },
    {
      "groupName": "i18next",
      "description": "Group i18next, react-i18next, and i18next plugins so peer-dep major bumps land together",
      "matchPackagePatterns": ["^i18next$", "^react-i18next$", "^i18next-"]
    }
  ],
  "ignoreDeps": [
    "github.com/pingcap/tidb/pkg/parser",
    "github.com/elastic/go-elasticsearch/v7"
  ]
}
